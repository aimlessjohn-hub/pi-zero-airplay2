[Unit]
Description=Shairport-Sync – AirPlay 2 Audio Receiver
Documentation=man:shairport-sync(7)
After=network-online.target nqptp.service
Wants=network-online.target nqptp.service

[Service]
Type=simple
ExecStart=/usr/local/bin/shairport-sync
Restart=on-failure
RestartSec=5
User=nobody
Group=nogroup
NoNewPrivileges=yes
ProtectSystem=full
ProtectHome=yes
PrivateTmp=yes
MemoryDenyWriteExecute=yes

[Install]
WantedBy=multi-user.target